# ColdTrace Backend — Environment Variables
# Copy this file to .env (never commit .env) and set these on Render's dashboard.

# ── Security ──────────────────────────────────────────────────────────────────

# URL of the deployed Vercel production frontend — used to restrict CORS.
# Use the production domain (e.g. cold-trace.vercel.app), NOT a preview URL
# (preview URLs contain "-git-main-" and have Deployment Protection enabled).
# No trailing slash. Must include https://
# Example: https://cold-trace.vercel.app
FRONTEND_URL=https://your-project-name.vercel.app

# Admin API key — RESERVED FOR FUTURE INTERNAL-ONLY ENDPOINTS ONLY.
# DO NOT wire this to any endpoint that has a public UI button.
# VITE_ env vars are compiled into the public JS bundle and are visible to
# anyone who opens browser devtools — sending a secret from the browser
# provides zero real protection.
# Use server-side rate limiting (slowapi) for public endpoints instead.
# Generate a strong value: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=replace-with-a-strong-random-secret

# ── Existing variables (already in use) ───────────────────────────────────────

# data.gov.in API key for HMIS wastage/outage data
DATA_GOV_IN_API_KEY=

# Gmail credentials for alert emails
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Notes ─────────────────────────────────────────────────────────────────────
# Render free tier fully supports environment variables at no cost.
# Set them at: https://dashboard.render.com → your service → Environment
#
# VITE_ADMIN_API_KEY should NOT exist on Vercel — it was removed because
# VITE_ vars are public. Delete it from Vercel if it was previously set.
# The only Vercel env var needed is VITE_API_URL (your Render backend URL).
