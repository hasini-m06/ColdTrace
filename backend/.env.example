# ColdTrace Backend — Environment Variables
# Copy this file to .env (never commit .env) and set these on Render's dashboard.

# ── Security ──────────────────────────────────────────────────────────────────

# URL of the deployed Vercel frontend — used to restrict CORS.
# Example: https://cold-trace-git-main-hasini-m06s-projects.vercel.app
# Set this on Render → Environment → Add Environment Variable
FRONTEND_URL=https://your-vercel-app.vercel.app

# Secret key required in the X-Admin-Key HTTP header to call POST /refresh.
# Generate a strong random string, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
# Set this on Render → Environment → Add Environment Variable
ADMIN_API_KEY=replace-with-a-strong-random-secret

# ── Existing variables (already in use) ───────────────────────────────────────

# data.gov.in API key for HMIS wastage/outage data
DATA_GOV_IN_API_KEY=

# Gmail credentials for alert emails
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Notes ─────────────────────────────────────────────────────────────────────
# Render free tier fully supports environment variables at no cost.
# Set them at: https://dashboard.render.com → your service → Environment
# Vercel env vars (if needed for frontend): https://vercel.com/dashboard → project → Settings → Environment Variables
